            margin-bottom: 30px; 
        }
        .language-switch button { 
            background: none;
            border: 1px solid #e2e8f0;
            color: #64748b; 
            padding: 6px 16px; 
            font-size: 0.9em;
            cursor: pointer;
            border-radius: 20px;
            transition: all 0.3s ease;
            font-family: inherit;
        }
        .language-switch button:hover {
            border-color: #007bff;
            color: #007bff;
        }
        .language-switch button.active {
            background-color: #007bff;
            color: #ffffff;
            border-color: #007bff;
        }
        .lang-separator {
            color: #cbd5e1;
            margin: 0 5px;
        }

        /* 底部信息 */
        hr { 
            border: none;
            border-top: 1px solid #edf2f7; 
            margin: 40px 0 20px 0; 
        }
        .footer { 
            text-align: center; 
            color: #94a3b8; 
            font-size: 0.9em; 
        }
    </style>
</head>
